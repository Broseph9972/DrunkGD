{
	"geode": "5.8.2",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "jqseph9972.drunkgd",
	"name": "Alchoholism",
	"version": "v1.0.0",
	"developer": "Jqseph9972",
	"description": "Configurable speed drift effect.",
	"settings": {
		"enabled": {
			"name": "Enable Effect",
			"type": "bool",
			"default": false,
			"description": "Toggles the drift effect."
		},
		"pause-menu-button": {
			"name": "Show Button in Pause Menu",
			"type": "bool",
			"default": false,
			"description": "Adds a pause-menu settings button."
		},
		"speed-viewer": {
			"name": "Show Speed Viewer",
			"type": "bool",
			"default": true,
			"description": "Shows the speed label in the top-right corner."
		},
		"preset": {
			"name": "Preset",
			"type": "custom:preset-selector",
			"default": "drunk",
			"enable-if": "enabled",
			"description": "Selects the active preset."
		},
		"advanced-title": {
			"name": "Advanced (Custom preset only)",
			"type": "title",
			"description": "Used only by the Custom preset."
		},
		"min-speed": {
			"name": "Min Speed",
			"type": "float",
			"default": 0.8,
			"min": 0.3,
			"max": 1.0,
			"control": {
				"slider": true
			},
			"enable-if": "enabled",
			"description": "Minimum speed multiplier."
		},
		"max-speed": {
			"name": "Max Speed",
			"type": "float",
			"default": 1.2,
			"min": 1.0,
			"max": 2.0,
			"control": {
				"slider": true
			},
			"enable-if": "enabled",
			"description": "Maximum speed multiplier."
		},
		"randomize-interval": {
			"name": "Randomize How Often",
			"type": "bool",
			"default": true,
			"enable-if": "enabled",
			"description": "Randomizes the interval."
		},
		"interval": {
			"name": "Interval",
			"type": "float",
			"default": 4.0,
			"min": 1.0,
			"max": 30.0,
			"control": {
				"slider": true
			},
			"enable-if": "enabled && !randomize-interval",
			"enable-if-description": "Only used when 'Randomize How Often' is off.",
			"description": "Fixed interval between changes."
		},
		"min-interval": {
			"name": "Min Interval",
			"type": "float",
			"default": 2.0,
			"min": 1.0,
			"max": 30.0,
			"control": {
				"slider": true
			},
			"enable-if": "enabled && randomize-interval",
			"enable-if-description": "Only used when 'Randomize How Often' is on.",
			"description": "Minimum randomized interval."
		},
		"max-interval": {
			"name": "Max Interval",
			"type": "float",
			"default": 6.0,
			"min": 1.0,
			"max": 60.0,
			"control": {
				"slider": true
			},
			"enable-if": "enabled && randomize-interval",
			"enable-if-description": "Only used when 'Randomize How Often' is on.",
			"description": "Maximum randomized interval."
		},
		"max-step": {
			"name": "Max Change Per Step",
			"type": "float",
			"default": 1.0,
			"min": 0.01,
			"max": 1.0,
			"control": {
				"slider": true
			},
			"enable-if": "enabled",
			"description": "Maximum change per step."
		},
		"transition-time": {
			"name": "Transition Time",
			"type": "float",
			"default": 0.7,
			"min": 0.0,
			"max": 8.0,
			"control": {
				"slider": true
			},
			"enable-if": "enabled",
			"description": "Time to move toward the next speed."
		},
		"music-speed": {
			"name": "Change Music Speed",
			"type": "bool",
			"default": true,
			"enable-if": "enabled",
			"description": "Also changes music pitch."
		},
		"screen-shake": {
			"name": "Screen Shake",
			"type": "bool",
			"default": false,
			"enable-if": "enabled",
			"description": "Shakes the screen during drift."
		},
		"gravity-drift": {
			"name": "Gravity Drift",
			"type": "bool",
			"default": false,
			"enable-if": "enabled",
			"description": "Adjusts gravity with speed."
		},
		"gravity-min": {
			"name": "Min Gravity",
			"type": "float",
			"default": 0.6,
			"min": 0.1,
			"max": 1.0,
			"control": {
				"slider": true
			},
			"enable-if": "enabled && gravity-drift",
			"enable-if-description": "Only used when 'Gravity Drift' is on.",
			"description": "Minimum gravity multiplier."
		},
		"gravity-max": {
			"name": "Max Gravity",
			"type": "float",
			"default": 1.4,
			"min": 1.0,
			"max": 2.5,
			"control": {
				"slider": true
			},
			"enable-if": "enabled && gravity-drift",
			"enable-if-description": "Only used when 'Gravity Drift' is on.",
			"description": "Maximum gravity multiplier."
		},
		"trolling-title": {
			"name": "Trolling",
			"type": "title",
			"description": "Temporary disable controls."
		},
		"panic-button-enabled": {
			"name": "Disable on button held",
			"type": "bool",
			"default": false,
			"enable-if": "enabled",
			"description": "Disables effects while held."
		},
		"panic-button": {
			"name": "Panic Button",
			"type": "keybind",
			"default": "CtrlLeft",
			"enable-if": "enabled && panic-button-enabled",
			"enable-if-description": "Only used when 'Disable on button held' is on.",
			"description": "Keybind used to disable effects."
		}
	}
}
